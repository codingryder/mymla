# ─── MyMLA WhatsApp Chatbot ─────────────────────────────────────────────────
# Copy to `.env` and fill the values. Loaded at import time via python-dotenv.

# ─── Postgres (Neon) ────────────────────────────────────────────────────────
NEON_DSN=postgresql://user:pass@host/db?sslmode=require

# ─── Meta WhatsApp Cloud API ────────────────────────────────────────────────
META_APP_ID=000000000000000
META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=000000000000000
META_WABA_ID=000000000000000
META_WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxx
META_WEBHOOK_VERIFY_TOKEN=pick-a-long-random-string
META_GRAPH_API_VERSION=v21.0

# ─── Sarvam AI (Malayalam voice STT) ────────────────────────────────────────
SARVAM_API_KEY=

# ─── Gemini (reserved for future AI features) ───────────────────────────────
GEMINI_API_KEY=

# ─── SendGrid ops alerts ────────────────────────────────────────────────────
SENDGRID_API_KEY=
ALERT_EMAIL_TO=ops@example.com
ALERT_EMAIL_FROM=alerts@example.com

# ─── App config ─────────────────────────────────────────────────────────────
BOT_BASE_URL=https://your-app.onrender.com
SESSION_TIMEOUT_MINUTES=30
MLA_NAME=Hon. MLA Name
MLA_CONSTITUENCY=Thiruvananthapuram
